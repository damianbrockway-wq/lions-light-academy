# Force every LLA PDF to download instead of opening in the browser's
# inline viewer. Required because Safari (Mac and iOS) ignores the HTML
# download attribute for PDFs and traps users in a preview with no
# controls — no Download, no Print, no Back. Content-Disposition is an
# HTTP-level instruction; the browser must obey.

/LLA_Enrollment_Application_Fillable.pdf
  Content-Disposition: attachment; filename="LLA-Enrollment-Application.pdf"

/docs/parent-packet.pdf
  Content-Disposition: attachment; filename="LLA-Parent-Packet.pdf"

